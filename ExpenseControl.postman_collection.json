{
  "info": {
    "name": "ExpenseControl API",
    "description": "Testes da API de Controle de Gastos. Suba a API com `dotnet run --launch-profile http` (base http://localhost:5269) e rode esta coleção no Postman (individual ou via Collection Runner). Os ids são capturados automaticamente nas criações e reutilizados via variáveis.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5269" },
    { "key": "personId", "value": "" },
    { "key": "minorId", "value": "" },
    { "key": "tempPersonId", "value": "" }
  ],
  "item": [
    {
      "name": "People",
      "item": [
        {
          "name": "POST create person (Carlos, adulto) -> 201",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('personId', pm.response.json().id);"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"name\":\"Carlos\",\"age\":30}" },
            "url": { "raw": "{{baseUrl}}/people", "host": ["{{baseUrl}}"], "path": ["people"] }
          }
        },
        {
          "name": "POST create minor (Pedro, 15) -> 201",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('minorId', pm.response.json().id);"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"name\":\"Pedro\",\"age\":15}" },
            "url": { "raw": "{{baseUrl}}/people", "host": ["{{baseUrl}}"], "path": ["people"] }
          }
        },
        {
          "name": "POST create person INVALIDO (REC02) -> 400",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 400', () => pm.response.to.have.status(400));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"name\":\"\",\"age\":-5}" },
            "url": { "raw": "{{baseUrl}}/people", "host": ["{{baseUrl}}"], "path": ["people"] }
          }
        },
        {
          "name": "GET list people -> 200",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));"
          ] } } ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/people", "host": ["{{baseUrl}}"], "path": ["people"] }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "POST expense do Carlos -> 201",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 201', () => pm.response.to.have.status(201));",
            "pm.test('type volta como texto', () => pm.expect(pm.response.json().type).to.eql('Expense'));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"description\":\"Mercado\",\"amount\":150.50,\"type\":\"Expense\",\"personId\":{{personId}}}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "POST income do Carlos -> 201",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 201', () => pm.response.to.have.status(201));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"description\":\"Salario\",\"amount\":3000,\"type\":\"Income\",\"personId\":{{personId}}}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "POST RN03 pessoa inexistente -> 404",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 404', () => pm.response.to.have.status(404));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"description\":\"Teste\",\"amount\":10,\"type\":\"Expense\",\"personId\":999999}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "POST REC01 valor 0 -> 400",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 400', () => pm.response.to.have.status(400));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"description\":\"Teste\",\"amount\":0,\"type\":\"Expense\",\"personId\":{{personId}}}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "POST RN02 menor + Income -> 400",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 400', () => pm.response.to.have.status(400));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"description\":\"Mesada\",\"amount\":50,\"type\":\"Income\",\"personId\":{{minorId}}}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "POST menor + Expense -> 201",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 201', () => pm.response.to.have.status(201));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"description\":\"Doce\",\"amount\":8.50,\"type\":\"Expense\",\"personId\":{{minorId}}}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "POST validacao type ausente -> 400",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 400', () => pm.response.to.have.status(400));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"description\":\"Teste\",\"amount\":10,\"personId\":{{personId}}}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "GET list transactions -> 200",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));"
          ] } } ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        }
      ]
    },
    {
      "name": "Totals",
      "item": [
        {
          "name": "GET totals -> 200",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "pm.test('tem people e overall', () => {",
            "  const b = pm.response.json();",
            "  pm.expect(b).to.have.property('people');",
            "  pm.expect(b).to.have.property('overall');",
            "});"
          ] } } ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/totals", "host": ["{{baseUrl}}"], "path": ["totals"] }
          }
        }
      ]
    },
    {
      "name": "RN01 Cascade flow",
      "item": [
        {
          "name": "1. Create temp person -> 201",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('tempPersonId', pm.response.json().id);"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"name\":\"Temp\",\"age\":40}" },
            "url": { "raw": "{{baseUrl}}/people", "host": ["{{baseUrl}}"], "path": ["people"] }
          }
        },
        {
          "name": "2. Create transaction for temp -> 201",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 201', () => pm.response.to.have.status(201));"
          ] } } ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\"description\":\"Sera apagada pelo cascade\",\"amount\":99,\"type\":\"Expense\",\"personId\":{{tempPersonId}}}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "3. DELETE temp person -> 204",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 204', () => pm.response.to.have.status(204));"
          ] } } ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/people/{{tempPersonId}}", "host": ["{{baseUrl}}"], "path": ["people", "{{tempPersonId}}"] }
          }
        },
        {
          "name": "4. DELETE temp de novo -> 404",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 404', () => pm.response.to.have.status(404));"
          ] } } ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/people/{{tempPersonId}}", "host": ["{{baseUrl}}"], "path": ["people", "{{tempPersonId}}"] }
          }
        },
        {
          "name": "5. GET transactions (RN01: as do temp sumiram) -> 200",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('status 200', () => pm.response.to.have.status(200));",
            "pm.test('RN01: transacoes do temp foram cascateadas', () => {",
            "  const tempId = String(pm.collectionVariables.get('tempPersonId'));",
            "  const gone = pm.response.json().every(t => String(t.personId) !== tempId);",
            "  pm.expect(gone).to.be.true;",
            "});"
          ] } } ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        }
      ]
    }
  ]
}
